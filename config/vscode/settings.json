    // ═══════════════════════════════════════════════════════════════
    //  SYNTAX HIGHLIGHTING — Token Colors
    //  Designed for maximum readability & bug prevention
    //  • Strings are clearly green
    //  • Numbers are distinct peach
    //  • Keywords pop in mauve
    //  • Types are bold yellow for easy scanning
    //  • Errors/invalids are immediately visible in red
    // ═══════════════════════════════════════════════════════════════
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            // ── Comments ─────────────────────────────────────────
            {
                "name": "Comments",
                "scope": [
                    "comment",
                    "comment.line",
                    "comment.block",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "foreground": "#6c7086",
                    "fontStyle": "italic"
                }
            },
            // ── Doc Comments (slightly brighter for visibility) ──
            {
                "name": "Doc Comments",
                "scope": [
                    "comment.block.documentation",
                    "comment.block.javadoc",
                    "string.quoted.docstring"
                ],
                "settings": {
                    "foreground": "#7f849c",
                    "fontStyle": "italic"
                }
            },
            // ── Keywords & Control Flow ──────────────────────────
            {
                "name": "Keywords",
                "scope": [
                    "keyword",
                    "keyword.control",
                    "keyword.operator.new",
                    "keyword.operator.expression",
                    "keyword.operator.logical",
                    "keyword.other"
                ],
                "settings": {
                    "foreground": "#cba6f7"
                }
            },
            {
                "name": "Control Flow (if/else/for/while/return)",
                "scope": [
                    "keyword.control.flow",
                    "keyword.control.conditional",
                    "keyword.control.loop",
                    "keyword.control.return",
                    "keyword.control.break",
                    "keyword.control.continue"
                ],
                "settings": {
                    "foreground": "#cba6f7",
                    "fontStyle": "bold"
                }
            },
            // ── Storage / Modifiers ──────────────────────────────
            {
                "name": "Storage Types (var, let, const, func, class)",
                "scope": [
                    "storage",
                    "storage.type",
                    "storage.modifier",
                    "keyword.var",
                    "keyword.const"
                ],
                "settings": {
                    "foreground": "#f38ba8"
                }
            },
            // ── Functions ────────────────────────────────────────
            {
                "name": "Function Declarations",
                "scope": [
                    "entity.name.function",
                    "meta.function-call entity.name.function",
                    "support.function"
                ],
                "settings": {
                    "foreground": "#89b4fa"
                }
            },
            {
                "name": "Function Parameters",
                "scope": [
                    "variable.parameter",
                    "meta.parameter"
                ],
                "settings": {
                    "foreground": "#fab387",
                    "fontStyle": "italic"
                }
            },
            // ── Variables ────────────────────────────────────────
            {
                "name": "Variables",
                "scope": [
                    "variable",
                    "variable.other",
                    "variable.other.readwrite"
                ],
                "settings": {
                    "foreground": "#cdd6f4"
                }
            },
            {
                "name": "Constants",
                "scope": [
                    "variable.other.constant",
                    "variable.other.enummember"
                ],
                "settings": {
                    "foreground": "#fab387"
                }
            },
            {
                "name": "Language Built-in Variables (this, self, super)",
                "scope": [
                    "variable.language",
                    "variable.language.this",
                    "variable.language.self",
                    "variable.language.super"
                ],
                "settings": {
                    "foreground": "#f38ba8",
                    "fontStyle": "italic"
                }
            },
            // ── Types & Classes ──────────────────────────────────
            {
                "name": "Types / Classes / Interfaces",
                "scope": [
                    "entity.name.type",
                    "entity.name.class",
                    "entity.name.namespace",
                    "entity.other.inherited-class",
                    "support.type",
                    "support.class"
                ],
                "settings": {
                    "foreground": "#f9e2af",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Type Parameters / Generics",
                "scope": [
                    "entity.name.type.parameter"
                ],
                "settings": {
                    "foreground": "#94e2d5",
                    "fontStyle": "italic"
                }
            },
            // ── Strings ──────────────────────────────────────────
            {
                "name": "Strings",
                "scope": [
                    "string",
                    "string.quoted",
                    "string.template"
                ],
                "settings": {
                    "foreground": "#a6e3a1"
                }
            },
            {
                "name": "String Interpolation / Template Expressions",
                "scope": [
                    "string.interpolated",
                    "punctuation.definition.template-expression",
                    "punctuation.section.embedded",
                    "meta.template.expression"
                ],
                "settings": {
                    "foreground": "#f5c2e7"
                }
            },
            {
                "name": "Escape Characters",
                "scope": [
                    "constant.character.escape"
                ],
                "settings": {
                    "foreground": "#f5c2e7"
                }
            },
            // ── Numbers ──────────────────────────────────────────
            {
                "name": "Numbers",
                "scope": [
                    "constant.numeric",
                    "constant.numeric.integer",
                    "constant.numeric.float",
                    "constant.numeric.hex"
                ],
                "settings": {
                    "foreground": "#fab387"
                }
            },
            // ── Booleans & Null ───────────────────────────────────
            {
                "name": "Boolean & Null",
                "scope": [
                    "constant.language",
                    "constant.language.boolean",
                    "constant.language.null",
                    "constant.language.undefined"
                ],
                "settings": {
                    "foreground": "#fab387",
                    "fontStyle": "bold"
                }
            },
            // ── Operators ────────────────────────────────────────
            {
                "name": "Operators",
                "scope": [
                    "keyword.operator",
                    "keyword.operator.arithmetic",
                    "keyword.operator.comparison",
                    "keyword.operator.assignment",
                    "keyword.operator.ternary"
                ],
                "settings": {
                    "foreground": "#89dceb"
                }
            },
            // ── Punctuation ──────────────────────────────────────
            {
                "name": "Punctuation (braces, brackets, parens, semicolons)",
                "scope": [
                    "punctuation",
                    "punctuation.definition",
                    "punctuation.separator",
                    "punctuation.terminator",
                    "meta.brace"
                ],
                "settings": {
                    "foreground": "#9399b2"
                }
            },
            // ── Properties & Fields ──────────────────────────────
            {
                "name": "Object Properties / Fields",
                "scope": [
                    "variable.other.property",
                    "variable.other.object.property",
                    "meta.object-literal.key",
                    "support.type.property-name"
                ],
                "settings": {
                    "foreground": "#b4befe"
                }
            },
            // ── Tags (HTML/JSX/XML) ──────────────────────────────
            {
                "name": "HTML/XML Tags",
                "scope": [
                    "entity.name.tag",
                    "punctuation.definition.tag"
                ],
                "settings": {
                    "foreground": "#cba6f7"
                }
            },
            {
                "name": "HTML/XML Attributes",
                "scope": [
                    "entity.other.attribute-name"
                ],
                "settings": {
                    "foreground": "#f9e2af",
                    "fontStyle": "italic"
                }
            },
            // ── CSS ──────────────────────────────────────────────
            {
                "name": "CSS Properties",
                "scope": [
                    "support.type.property-name.css",
                    "meta.property-name.css"
                ],
                "settings": {
                    "foreground": "#89b4fa"
                }
            },
            {
                "name": "CSS Values",
                "scope": [
                    "support.constant.property-value.css",
                    "meta.property-value.css"
                ],
                "settings": {
                    "foreground": "#fab387"
                }
            },
            {
                "name": "CSS Selectors",
                "scope": [
                    "entity.other.attribute-name.class.css",
                    "entity.other.attribute-name.id.css"
                ],
                "settings": {
                    "foreground": "#f9e2af"
                }
            },
            {
                "name": "CSS Units",
                "scope": [
                    "keyword.other.unit.css"
                ],
                "settings": {
                    "foreground": "#f38ba8"
                }
            },
            // ── Regex ────────────────────────────────────────────
            {
                "name": "Regex",
                "scope": [
                    "string.regexp",
                    "constant.other.character-class.regexp"
                ],
                "settings": {
                    "foreground": "#f5c2e7"
                }
            },
            // ── Decorators / Annotations ─────────────────────────
            {
                "name": "Decorators / Annotations",
                "scope": [
                    "meta.decorator",
                    "meta.annotation",
                    "punctuation.decorator"
                ],
                "settings": {
                    "foreground": "#f5c2e7",
                    "fontStyle": "italic"
                }
            },
            // ── Markdown ─────────────────────────────────────────
            {
                "name": "Markdown Headings",
                "scope": [
                    "heading.1.markdown",
                    "heading.2.markdown",
                    "heading.3.markdown",
                    "markup.heading"
                ],
                "settings": {
                    "foreground": "#f38ba8",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Markdown Bold",
                "scope": [
                    "markup.bold"
                ],
                "settings": {
                    "foreground": "#f38ba8",
                    "fontStyle": "bold"
                }
            },
            {
                "name": "Markdown Italic",
                "scope": [
                    "markup.italic"
                ],
                "settings": {
                    "foreground": "#f38ba8",
                    "fontStyle": "italic"
                }
            },
            {
                "name": "Markdown Links",
                "scope": [
                    "markup.underline.link"
                ],
                "settings": {
                    "foreground": "#89b4fa"
                }
            },
            {
                "name": "Markdown Code",
                "scope": [
                    "markup.inline.raw",
                    "markup.fenced_code.block"
                ],
                "settings": {
                    "foreground": "#a6e3a1"
                }
            },
            // ── JSON Keys ────────────────────────────────────────
            {
                "name": "JSON Keys Level 0",
                "scope": [
                    "support.type.property-name.json"
                ],
                "settings": {
                    "foreground": "#89b4fa"
                }
            },
            // ── Go Specific ──────────────────────────────────────
            {
                "name": "Go Package Names",
                "scope": [
                    "entity.name.import.go"
                ],
                "settings": {
                    "foreground": "#a6e3a1"
                }
            },
            {
                "name": "Go Builtins (make, len, cap, append, etc.)",
                "scope": [
                    "support.function.builtin.go"
                ],
                "settings": {
                    "foreground": "#f5c2e7"
                }
            },
            // ── Dart / Flutter Specific ──────────────────────────
            {
                "name": "Dart Annotations (@override, @required, etc.)",
                "scope": [
                    "storage.type.annotation.dart"
                ],
                "settings": {
                    "foreground": "#f5c2e7",
                    "fontStyle": "italic"
                }
            },
            // ── Invalid / Deprecated (bug prevention) ────────────
            {
                "name": "Invalid / Illegal",
                "scope": [
                    "invalid",
                    "invalid.illegal"
                ],
                "settings": {
                    "foreground": "#f38ba8",
                    "fontStyle": "underline bold"
                }
            },
            {
                "name": "Deprecated",
                "scope": [
                    "invalid.deprecated"
                ],
                "settings": {
                    "foreground": "#fab387",
                    "fontStyle": "strikethrough"
                }
            }
        ]
    },
    // ── Semantic Token Colors (modern language servers) ───────────
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "namespace": "#f9e2af",
            "type": "#f9e2af",
            "class": {
                "foreground": "#f9e2af",
                "bold": true
            },
            "interface": {
                "foreground": "#f9e2af",
                "italic": true
            },
            "struct": "#f9e2af",
            "enum": "#f9e2af",
            "enumMember": "#fab387",
            "typeParameter": {
                "foreground": "#94e2d5",
                "italic": true
            },
            "function": "#89b4fa",
            "method": "#89b4fa",
            "macro": "#cba6f7",
            "variable": "#cdd6f4",
            "variable.readonly": "#fab387",
            "variable.defaultLibrary": {
                "foreground": "#f38ba8",
                "italic": true
            },
            "parameter": {
                "foreground": "#fab387",
                "italic": true
            },
            "property": "#b4befe",
            "property.readonly": "#fab387",
            "string": "#a6e3a1",
            "number": "#fab387",
            "keyword": "#cba6f7",
            "operator": "#89dceb",
            "comment": {
                "foreground": "#6c7086",
                "italic": true
            },
            "decorator": {
                "foreground": "#f5c2e7",
                "italic": true
            },
            "regexp": "#f5c2e7"
        }
    }
}