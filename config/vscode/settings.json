{
    // ═══════════════════════════════════════════════════════════════
    //  ANTIGRAVITY IDE — Catppuccin Mocha × Void Black
    //  Optimized for: productivity, readability, bug prevention
    //  Base: Catppuccin Mocha palette | BG override: #11111b
    // ═══════════════════════════════════════════════════════════════
    "security.workspace.trust.startupPrompt": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    // ── Dart ──────────────────────────────────────────────────────
    "[dart]": {
        "editor.formatOnSave": true,
        "editor.formatOnType": true,
        "editor.rulers": [
            80
        ],
        "editor.selectionHighlight": false,
        "editor.tabCompletion": "onlySnippets",
        "editor.wordBasedSuggestions": "off"
    },
    // ── Claude Code ──────────────────────────────────────────────
    "claudeCode.preferredLocation": "panel",
    "claudeCode.selectedModel": "sonnet",
    // ── Font & Editor ────────────────────────────────────────────
    "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Fira Code', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 15,
    "editor.lineHeight": 1.6,
    "editor.cursorBlinking": "smooth",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.minimap.enabled": true,
    "editor.minimap.side": "left",
    "editor.scrollbar.vertical": "visible",
    "editor.renderLineHighlight": "none",
    "editor.overviewRulerBorder": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.folding": false,
    "editor.glyphMargin": false,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.matchBrackets": "always",
    "editor.stickyScroll.enabled": true,
    // ── Terminal ──────────────────────────────────────────────────
    "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
    "terminal.integrated.fontSize": 15,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.macOptionIsMeta": true,
    // ── Window & Layout ──────────────────────────────────────────
    "window.density.editorTabHeight": "compact",
    "workbench.editor.tabSizing": "shrink",
    "window.titleBarStyle": "custom",
    "workbench.activityBar.location": "top",
    "workbench.sideBar.location": "left",
    "workbench.layoutControl.enabled": false,
    "window.commandCenter": false,
    "breadcrumbs.enabled": true,
    "workbench.editor.labelFormat": "medium",
    "window.title": "${activeEditorMedium}${separator}${rootName}",
    "workbench.statusBar.visible": false,
